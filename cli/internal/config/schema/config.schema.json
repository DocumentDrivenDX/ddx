{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ddx-tools.github.io/schemas/config.schema.json",
  "title": "DDx Configuration Schema",
  "description": "Schema for DDx project configuration files (.ddx/config.yaml)",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Configuration schema version (e.g., '1.0')",
      "examples": [
        "1.0"
      ]
    },
    "library": {
      "type": "object",
      "description": "Library configuration for DDx resources",
      "properties": {
        "path": {
          "type": "string",
          "default": "./library",
          "description": "Path to DDx library relative to config.yaml",
          "examples": [
            "./library",
            "../shared/ddx-library",
            "/opt/ddx/library"
          ]
        },
        "repository": {
          "type": "object",
          "description": "Repository configuration for git subtree synchronization",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "DDx repository URL",
              "examples": [
                "https://github.com/easel/ddx",
                "https://github.com/company/ddx-enterprise"
              ]
            },
            "branch": {
              "type": "string",
              "description": "Branch to sync from repository",
              "default": "main",
              "examples": [
                "main",
                "master",
                "stable",
                "v2"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "bead": {
      "type": "object",
      "description": "Bead tracker configuration",
      "properties": {
        "id_prefix": {
          "type": "string",
          "minLength": 1,
          "description": "Override the bead ID prefix used by the tracker",
          "examples": [
            "nif",
            "bx"
          ]
        }
      },
      "additionalProperties": false
    },
    "persona_bindings": {
      "type": "object",
      "description": "Bindings between roles and persona names",
      "additionalProperties": {
        "type": "string",
        "description": "Persona name for the role"
      },
      "examples": [
        {
          "code-reviewer": "strict-reviewer",
          "test-engineer": "tdd-engineer"
        }
      ]
    },
    "system": {
      "type": "object",
      "description": "System-level configuration settings",
      "properties": {
        "meta_prompt": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to meta-prompt file (null to disable)",
          "examples": [
            "claude/system-prompts/focused.md",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "update_check": {
      "type": "object",
      "description": "Automatic update check configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic update checks"
        },
        "frequency": {
          "type": "string",
          "default": "24h",
          "pattern": "^\\d+[hdwmy]$",
          "description": "Check frequency (Go duration format: h=hours, d=days, w=weeks, m=months, y=years)",
          "examples": [
            "24h",
            "12h",
            "7d",
            "1w"
          ]
        }
      },
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "description": "Git integration configuration",
      "properties": {
        "auto_commit": {
          "type": "string",
          "enum": [
            "always",
            "prompt",
            "never"
          ],
          "default": "never",
          "description": "Auto-commit mode for document writes (always | prompt | never)"
        },
        "commit_prefix": {
          "type": "string",
          "default": "docs",
          "description": "Prefix for auto-commit messages",
          "examples": [
            "docs",
            "chore"
          ]
        },
        "checkpoint_prefix": {
          "type": "string",
          "description": "Prefix for checkpoint commit messages",
          "examples": [
            "checkpoint",
            "wip"
          ]
        }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "description": "Agent service configuration",
      "properties": {
        "harness": {
          "type": "string",
          "description": "Default harness name (e.g., codex, claude, gemini)",
          "examples": [
            "codex",
            "claude",
            "gemini"
          ]
        },
        "model": {
          "type": "string",
          "description": "Global model override for agent invocation",
          "examples": [
            "o3-mini",
            "claude-sonnet-4-20250514"
          ]
        },
        "models": {
          "type": "object",
          "description": "Per-harness model overrides",
          "additionalProperties": {
            "type": "string"
          },
          "examples": [
            {
              "codex": "o3-mini",
              "claude": "claude-sonnet-4-20250514"
            }
          ]
        },
        "reasoning_levels": {
          "type": "object",
          "description": "Per-harness reasoning-level options",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": [
            {
              "codex": [
                "low",
                "medium",
                "high"
              ]
            }
          ]
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Default timeout in milliseconds",
          "default": 300000,
          "examples": [
            300000,
            600000
          ]
        },
        "session_log_dir": {
          "type": "string",
          "description": "Directory for agent session logs",
          "default": ".ddx/agent-logs",
          "examples": [
            ".ddx/agent-logs",
            "/tmp/agent-logs"
          ]
        },
        "permissions": {
          "type": "string",
          "description": "Default permission level for agent invocations",
          "enum": [
            "safe",
            "supervised",
            "unrestricted"
          ]
        },
        "agent_runner": {
          "type": "object",
          "description": "Configuration for the DDx agent harness",
          "properties": {
            "provider": {
              "type": "string",
              "description": "Provider type: openai-compat or anthropic",
              "examples": [
                "openai-compat",
                "anthropic"
              ]
            },
            "base_url": {
              "type": "string",
              "description": "Provider endpoint URL",
              "examples": [
                "http://localhost:1234/v1"
              ]
            },
            "api_key": {
              "type": "string",
              "description": "API key for the provider"
            },
            "model": {
              "type": "string",
              "description": "Default model name"
            },
            "preset": {
              "type": "string",
              "description": "Prompt preset (forge/codex/claude/cursor/minimal)",
              "examples": [
                "forge",
                "minimal"
              ]
            },
            "max_iterations": {
              "type": "integer",
              "description": "Maximum tool-call rounds",
              "default": 20
            },
            "models": {
              "type": "object",
              "description": "Named LLM presets with optional multi-endpoint support",
              "additionalProperties": {
                "type": "object",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "Model name passed to the provider"
                  },
                  "provider": {
                    "type": "string",
                    "description": "Provider override"
                  },
                  "endpoints": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "One or more base URLs; multiple = load balanced"
                  },
                  "api_key": {
                    "type": "string",
                    "description": "API key override"
                  },
                  "strategy": {
                    "type": "string",
                    "description": "Endpoint selection strategy",
                    "enum": [
                      "round-robin",
                      "first-available"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "virtual": {
          "type": "object",
          "description": "Configuration for the virtual agent harness",
          "properties": {
            "normalize": {
              "type": "array",
              "description": "Regex/replacement pairs applied to prompts before hashing",
              "items": {
                "type": "object",
                "required": [
                  "pattern",
                  "replace"
                ],
                "properties": {
                  "pattern": {
                    "type": "string",
                    "description": "Regular expression to match"
                  },
                  "replace": {
                    "type": "string",
                    "description": "Replacement string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "description": "Server configuration for ddx-server",
      "properties": {
        "addr": {
          "type": "string",
          "description": "Listen address for the server",
          "examples": [
            ":8080",
            "127.0.0.1:8080"
          ]
        },
        "tsnet": {
          "type": "object",
          "description": "Tailscale ts-net listener configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Tailscale ts-net listener"
            },
            "hostname": {
              "type": "string",
              "description": "Tailscale hostname for the server"
            },
            "auth_key": {
              "type": "string",
              "description": "Tailscale auth key"
            },
            "state_dir": {
              "type": "string",
              "description": "Directory for Tailscale state storage"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/easel/ddx",
          "branch": "main"
        }
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/company/ddx-enterprise",
          "branch": "stable"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-reviewer",
        "test-engineer": "tdd-engineer"
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": ".ddx/plugins/ddx",
        "repository": {
          "url": "https://github.com/easel/ddx-library",
          "branch": "main"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-code-reviewer"
      }
    }
  ]
}
