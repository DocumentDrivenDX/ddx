{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ddx-tools.github.io/schemas/config.schema.json",
  "title": "DDx Configuration Schema",
  "description": "Schema for DDx project configuration files (.ddx/config.yaml)",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Configuration schema version (e.g., '1.0')",
      "examples": [
        "1.0"
      ]
    },
    "library": {
      "type": "object",
      "description": "Library configuration for DDx resources",
      "properties": {
        "path": {
          "type": "string",
          "default": "./library",
          "description": "Path to DDx library relative to config.yaml",
          "examples": [
            "./library",
            "../shared/ddx-library",
            "/opt/ddx/library"
          ]
        },
        "repository": {
          "type": "object",
          "description": "Library remote repository (URL + branch) for resource discovery",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "DDx repository URL",
              "examples": [
                "https://github.com/easel/ddx",
                "https://github.com/company/ddx-enterprise"
              ]
            },
            "branch": {
              "type": "string",
              "description": "Branch to sync from repository",
              "default": "main",
              "examples": [
                "main",
                "master",
                "stable",
                "v2"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "bead": {
      "type": "object",
      "description": "Bead tracker configuration",
      "properties": {
        "id_prefix": {
          "type": "string",
          "minLength": 1,
          "description": "Override the bead ID prefix used by the tracker",
          "examples": [
            "nif",
            "bx"
          ]
        },
        "backend": {
          "type": "string",
          "enum": [
            "jsonl",
            "bd",
            "br",
            "axon"
          ],
          "description": "Select the bead storage backend",
          "examples": [
            "jsonl",
            "axon"
          ]
        }
      },
      "additionalProperties": false
    },
    "bead-quality": {
      "type": "object",
      "description": "Bead quality gates that run before dispatch",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["warn-only", "block", "factory"],
          "description": "Whether bead-quality findings warn and proceed or may block dispatch"
        },
        "lint": {
          "type": "object",
          "description": "Pre-dispatch bead quality lint settings",
          "properties": {
            "block_threshold_score": {
              "type": "integer",
              "minimum": 0,
              "description": "If positive, block dispatch when lint score falls below this threshold. Zero or unset keeps warn-only behavior."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "prose": {
      "type": "object",
      "description": "Deterministic prose-quality workflow settings",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["technical", "planning", "public"],
          "description": "Rule pack to apply to prose checks"
        },
        "severity": {
          "type": "string",
          "enum": ["advisory", "warning", "blocking"],
          "description": "Severity attached to emitted prose findings"
        },
        "policy": {
          "type": "string",
          "enum": ["advisory", "blocking"],
          "description": "Exit-policy for prose findings"
        },
        "runner": {
          "type": "string",
          "enum": ["embedded", "vale", "auto"],
          "description": "Optional runner selection for prose checks"
        },
        "includes": {
          "type": "array",
          "description": "Markdown path globs to include",
          "items": {
            "type": "string"
          }
        },
        "excludes": {
          "type": "array",
          "description": "Markdown path globs to exclude",
          "items": {
            "type": "string"
          }
        },
        "vocabulary": {
          "type": "object",
          "description": "Project terminology to preserve or reject",
          "properties": {
            "accept": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reject": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "persona_bindings": {
      "type": "object",
      "description": "Bindings between roles and persona names",
      "additionalProperties": {
        "type": "string",
        "description": "Persona name for the role"
      },
      "examples": [
        {
          "code-reviewer": "strict-reviewer",
          "test-engineer": "tdd-engineer"
        }
      ]
    },
    "system": {
      "type": "object",
      "description": "System-level configuration settings",
      "properties": {
        "meta_prompt": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to meta-prompt file (null to disable)",
          "examples": [
            "claude/system-prompts/focused.md",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "update_check": {
      "type": "object",
      "description": "Automatic update check configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic update checks"
        },
        "frequency": {
          "type": "string",
          "default": "24h",
          "pattern": "^\\d+[hdwmy]$",
          "description": "Check frequency (Go duration format: h=hours, d=days, w=weeks, m=months, y=years)",
          "examples": [
            "24h",
            "12h",
            "7d",
            "1w"
          ]
        }
      },
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "description": "Git integration configuration",
      "properties": {
        "auto_commit": {
          "type": "string",
          "enum": [
            "always",
            "prompt",
            "never"
          ],
          "default": "never",
          "description": "Auto-commit mode for document writes (always | prompt | never)"
        },
        "commit_prefix": {
          "type": "string",
          "default": "docs",
          "description": "Prefix for auto-commit messages",
          "examples": [
            "docs",
            "chore"
          ]
        },
        "checkpoint_prefix": {
          "type": "string",
          "description": "Prefix for checkpoint commit messages",
          "examples": [
            "checkpoint",
            "wip"
          ]
        },
        "post_land_command": {
          "type": "array",
          "description": "Command argv to run after a local automatic land advances the target ref and before push",
          "items": {
            "type": "string"
          },
          "examples": [
            [
              "make",
              "test"
            ],
            [
              "sh",
              "-c",
              "go test ./..."
            ]
          ]
        },
        "large_deletion_line_threshold": {
          "type": "integer",
          "minimum": 1,
          "default": 200,
          "description": "Per-file deleted-line threshold for preserving unacknowledged large-deletion land results"
        }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "description": "Agent service configuration",
      "properties": {
        "model": {
          "type": "string",
          "description": "Global model override for agent invocation",
          "examples": [
            "o3-mini",
            "claude-sonnet-4-20250514"
          ]
        },
        "models": {
          "type": "object",
          "description": "Per-harness model overrides",
          "additionalProperties": {
            "type": "string"
          },
          "examples": [
            {
              "codex": "o3-mini",
              "claude": "claude-sonnet-4-20250514"
            }
          ]
        },
        "reasoning_levels": {
          "type": "object",
          "description": "Per-harness reasoning-level options",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": [
            {
              "codex": [
                "low",
                "medium",
                "high"
              ]
            }
          ]
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Default timeout in milliseconds",
          "default": 300000,
          "examples": [
            300000,
            600000
          ]
        },
        "session_log_dir": {
          "type": "string",
          "description": "Directory for agent session logs",
          "default": ".ddx/agent-logs",
          "examples": [
            ".ddx/agent-logs",
            "/tmp/agent-logs"
          ]
        },
        "permissions": {
          "type": "string",
          "description": "Default permission level for agent invocations",
          "enum": [
            "safe",
            "supervised",
            "unrestricted"
          ]
        },
        "endpoints": {
          "type": "array",
          "description": "Endpoint-first native agent provider targets. These blocks intentionally omit provider profile names and model pins; routing discovers live models from /v1/models.",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Provider endpoint type, such as lmstudio, omlx, ollama, openrouter, or openai"
              },
              "host": {
                "type": "string",
                "description": "Endpoint host used with port when base_url is omitted"
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535,
                "description": "Endpoint port used with host when base_url is omitted"
              },
              "base_url": {
                "type": "string",
                "description": "OpenAI-compatible base URL, for example http://vidar:1235/v1"
              },
              "api_key": {
                "type": "string",
                "description": "Optional endpoint API key"
              }
            },
            "additionalProperties": false,
            "anyOf": [
              {
                "required": [
                  "base_url"
                ]
              },
              {
                "required": [
                  "host",
                  "port"
                ]
              }
            ]
          }
        },
        "routing": {
          "type": "object",
          "description": "Model routing configuration",
          "properties": {
            "profile_priority": {
              "type": "array",
              "description": "DEPRECATED: flat ordered list of profiles to prefer.",
              "deprecated": true,
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "virtual": {
          "type": "object",
          "description": "Configuration for the virtual agent harness",
          "properties": {
            "normalize": {
              "type": "array",
              "description": "Regex/replacement pairs applied to prompts before hashing",
              "items": {
                "type": "object",
                "required": [
                  "pattern",
                  "replace"
                ],
                "properties": {
                  "pattern": {
                    "type": "string",
                    "description": "Regular expression to match"
                  },
                  "replace": {
                    "type": "string",
                    "description": "Replacement string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "description": "Server configuration for ddx-server",
      "properties": {
        "addr": {
          "type": "string",
          "description": "Listen address for the server",
          "examples": [
            ":8080",
            "127.0.0.1:8080"
          ]
        },
        "tsnet": {
          "type": "object",
          "description": "Tailscale ts-net listener configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Tailscale ts-net listener"
            },
            "hostname": {
              "type": "string",
              "description": "Tailscale hostname for the server"
            },
            "auth_key": {
              "type": "string",
              "description": "Tailscale auth key"
            },
            "state_dir": {
              "type": "string",
              "description": "Directory for Tailscale state storage"
            }
          },
          "additionalProperties": false
        },
        "watchdog_deadline": {
          "type": "string",
          "description": "Total worker runtime budget before the autonomous watchdog considers reaping (time.ParseDuration, e.g. '6h'). Empty uses the built-in default."
        },
        "stall_deadline": {
          "type": "string",
          "description": "Max time the current attempt may sit without a phase transition before the watchdog treats it as stalled (time.ParseDuration, e.g. '1h'). Empty uses the built-in default."
        }
      },
      "additionalProperties": false
    },
    "executions": {
      "type": "object",
      "description": "Configuration for the bead execution bundle archive (mirror).",
      "properties": {
        "mirror": {
          "type": "object",
          "description": "Out-of-band mirror target for .ddx/executions/<attempt>/ bundles.",
          "properties": {
            "kind": {
              "type": "string",
              "description": "Mirror backend kind. Currently 'local' (more backends planned).",
              "enum": ["local"]
            },
            "path": {
              "type": "string",
              "description": "Mirror destination. Templates support {project}, {attempt_id}, {date}, {bead_id}.",
              "examples": [
                "/var/lib/ddx-mirror/{project}/{attempt_id}",
                "/mnt/archive/{date}/{bead_id}/{attempt_id}"
              ]
            },
            "include": {
              "type": "array",
              "description": "Bundle parts to upload. Defaults to manifest, prompt, result, usage, checks, embedded.",
              "items": {
                "type": "string",
                "enum": ["manifest", "prompt", "result", "usage", "checks", "embedded"]
              }
            },
            "async": {
              "type": "boolean",
              "description": "Upload in a background goroutine (default true) so ddx try never blocks on the mirror."
            }
          },
          "additionalProperties": false
        },
        "retain_days": {
          "type": "integer",
          "description": "Optional local retention policy. Bundles older than this are subject to local pruning while the mirror keeps full history.",
          "minimum": 0
        },
        "attempt_backend": {
          "type": "string",
          "description": "Workspace/transport backend for execute-bead attempts. Empty defaults to linked worktrees.",
          "enum": ["worktree", "local-clone", "docker-clone"]
        },
        "temp_worktree_root": {
          "type": "string",
          "description": "Base directory for isolated bead attempt worktrees. Relative paths in project config resolve against the project root; relative paths in global config resolve against the user's home directory. DDX_EXEC_WT_DIR overrides this value. Empty defaults to the per-user cache root, not /tmp.",
          "examples": [
            "~/.cache/ddx/exec-wt",
            ".ddx/worktrees",
            "/var/tmp/ddx-exec-wt"
          ]
        },
        "docker": {
          "type": "object",
          "description": "Settings for the docker-clone attempt backend.",
          "properties": {
            "image": {
              "type": "string",
              "description": "Container image used to run the attempt. DDx mounts the current ddx binary into the container and runs ddx run inside /work."
            },
            "memory": {
              "type": "string",
              "description": "Docker --memory value, e.g. 8g."
            },
            "memory_swap": {
              "type": "string",
              "description": "Docker --memory-swap value. Set equal to memory to disable container swap."
            },
            "cpus": {
              "type": "string",
              "description": "Docker --cpus value, e.g. 4."
            },
            "pids_limit": {
              "type": "integer",
              "minimum": 1,
              "description": "Docker --pids-limit value."
            },
            "tmpfs_size": {
              "type": "string",
              "description": "Size for the private /tmp tmpfs mounted in the attempt container, e.g. 2g. Defaults to 2g."
            },
            "network": {
              "type": "string",
              "description": "Docker --network value. Empty uses Docker's default network."
            },
            "clone_mode": {
              "type": "string",
              "description": "Local clone strategy before mounting into Docker.",
              "enum": ["hardlink", "copy", "no-hardlinks"]
            },
            "keep_on_error": {
              "type": "boolean",
              "description": "Preserve the local attempt clone when the docker backend cleans up."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "description": "Optional cost-estimation settings. DDx does not invent local compute rates when this block is absent.",
      "properties": {
        "local_per_1k_tokens": {
          "type": "number",
          "minimum": 0,
          "description": "Optional local compute estimate in USD per 1,000 tokens for locally served sessions."
        }
      },
      "additionalProperties": false
    },
    "workers": {
      "type": "object",
      "description": "Defaults and safety rails for the workers overview (+ Add worker / − Remove worker count control).",
      "properties": {
        "default_spec": {
          "type": "object",
          "description": "Default worker spec used by + Add worker on the workers overview. Any field left unset falls back to `ddx work` defaults.",
          "properties": {
            "profile": {
              "type": "string",
              "description": "Default routing profile (e.g. default, cheap, fast, smart)."
            },
            "effort": {
              "type": "string",
              "description": "Default reasoning-effort power class (low, medium, high)."
            }
          },
          "additionalProperties": false
        },
        "max_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional cap on running drain workers. + Add worker refuses to exceed this limit. Unset = no cap."
        },
        "no_progress_cooldown": {
          "type": "string",
          "description": "Cooldown applied to a bead that returns no_changes (or another no-progress status) so the queue can move on. Parsed via time.ParseDuration (e.g. \"6h\"). Empty or unparseable falls back to the built-in default (6h)."
        },
        "max_no_changes_before_close": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of consecutive no_changes attempts the drain loop tolerates before closing the bead as already_satisfied. Unset or non-positive falls back to the built-in default (3)."
        },
        "heartbeat_interval": {
          "type": "string",
          "description": "How often a claim owner refreshes its heartbeat while holding a bead. Parsed via time.ParseDuration (e.g. \"15s\"). Empty or unparseable falls back to the built-in default (30s)."
        }
      },
      "additionalProperties": false
    },
    "evidence_caps": {
      "type": "object",
      "description": "Byte-size caps used by the shared evidence-assembly primitives (FEAT-022 §1a). Project-level fields override the built-in defaults; entries in per_harness further override the project-level values for that harness name.",
      "properties": {
        "max_prompt_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total prompt cap in bytes. Default: 4 MiB."
        },
        "max_inlined_file_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Cap on a single inlined file's bytes. Default: 512 KiB."
        },
        "max_diff_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Cap on the assembled diff section's bytes. Default: 2 MiB."
        },
        "max_governing_doc_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Cap on a single governing document's inlined bytes. Default: 256 KiB."
        },
        "per_harness": {
          "type": "object",
          "description": "Per-harness overrides. Keys are harness names; values override the project-level caps for that harness only.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "max_prompt_bytes": {"type": "integer", "minimum": 0},
              "max_inlined_file_bytes": {"type": "integer", "minimum": 0},
              "max_diff_bytes": {"type": "integer", "minimum": 0},
              "max_governing_doc_bytes": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          }
        },
        "context_budget": {
          "type": "string",
          "description": "Prompt budget label that ddx try consults when assembling the bead prompt. Empty string means full budget; \"minimal\" omits large governing documents (cheap-power class path). See SD-024 §Stage 3."
        }
      },
      "additionalProperties": false
    },
    "triage": {
      "type": "object",
      "description": "Post-attempt triage decision policy used by the drain loop after each terminal event. Distinct from agent.triage (the bead readiness gate).",
      "properties": {
        "policies": {
          "type": "object",
          "description": "Per-failure-mode action ladders. Each rung is the action returned the nth time the mode is seen in a bead's history.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "re_attempt_with_context",
                "escalate_power",
                "retry_with_backoff",
                "file_followup",
                "operator_required"
              ]
            }
          },
          "propertyNames": {
            "enum": [
              "review_block",
              "lock_contention",
              "execution_failed",
              "no_changes"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "review_max_retries": {
      "type": "integer",
      "minimum": 0,
      "description": "Cap on reviewer attempts per committed result_rev before the drain loop emits a terminal `review-manual-required` event and parks the bead (FEAT-022 §14). Defaults to 3 when unset; non-positive values fall back to the default."
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/easel/ddx",
          "branch": "main"
        }
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/company/ddx-enterprise",
          "branch": "stable"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-reviewer",
        "test-engineer": "tdd-engineer"
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": ".ddx/plugins/ddx",
        "repository": {
          "url": "https://github.com/easel/ddx-library",
          "branch": "main"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-code-reviewer"
      }
    }
  ]
}
