{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ddx-tools.github.io/schemas/config.schema.json",
  "title": "DDx Configuration Schema",
  "description": "Schema for DDx project configuration files (.ddx/config.yaml)",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Configuration schema version (e.g., '1.0')",
      "examples": ["1.0"]
    },
    "library": {
      "type": "object",
      "description": "Library configuration for DDx resources",
      "properties": {
        "path": {
          "type": "string",
          "default": "./library",
          "description": "Path to DDx library relative to config.yaml",
          "examples": ["./library", "../shared/ddx-library", "/opt/ddx/library"]
        },
        "repository": {
          "type": "object",
          "description": "Repository configuration for git subtree synchronization",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "DDx repository URL",
              "examples": [
                "https://github.com/easel/ddx",
                "https://github.com/company/ddx-enterprise"
              ]
            },
            "branch": {
              "type": "string",
              "description": "Branch to sync from repository",
              "default": "main",
              "examples": ["main", "master", "stable", "v2"]
            },
            "subtree": {
              "type": "string",
              "description": "Path within repository to sync (what gets synced to library path)",
              "default": "library",
              "examples": ["library", "assets", "content"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "persona_bindings": {
      "type": "object",
      "description": "Bindings between roles and persona names",
      "additionalProperties": {
        "type": "string",
        "description": "Persona name for the role"
      },
      "examples": [
        {
          "code-reviewer": "strict-reviewer",
          "test-engineer": "tdd-engineer"
        }
      ]
    },
    "system": {
      "type": "object",
      "description": "System-level configuration settings",
      "properties": {
        "meta_prompt": {
          "type": ["string", "null"],
          "description": "Path to meta-prompt file (null to disable)",
          "examples": ["claude/system-prompts/focused.md", null]
        }
      },
      "additionalProperties": false
    },
    "update_check": {
      "type": "object",
      "description": "Automatic update check configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic update checks"
        },
        "frequency": {
          "type": "string",
          "default": "24h",
          "pattern": "^\\d+[hdwmy]$",
          "description": "Check frequency (Go duration format: h=hours, d=days, w=weeks, m=months, y=years)",
          "examples": ["24h", "12h", "7d", "1w"]
        }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "description": "Agent service configuration",
      "properties": {
        "harness": {
          "type": "string",
          "description": "Default harness name (e.g., codex, claude, gemini)",
          "examples": ["codex", "claude", "gemini"]
        },
        "models": {
          "type": "object",
          "description": "Per-harness model overrides",
          "additionalProperties": {
            "type": "string"
          },
          "examples": [{"codex": "o3-mini", "claude": "claude-sonnet-4-20250514"}]
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Default timeout in milliseconds",
          "default": 300000,
          "examples": [300000, 600000]
        },
        "session_log_dir": {
          "type": "string",
          "description": "Directory for agent session logs",
          "default": ".ddx/agent-logs",
          "examples": [".ddx/agent-logs", "/tmp/agent-logs"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/easel/ddx",
          "branch": "main",
          "subtree": "library"
        }
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": "./library",
        "repository": {
          "url": "https://github.com/company/ddx-enterprise",
          "branch": "stable",
          "subtree": "assets"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-reviewer",
        "test-engineer": "tdd-engineer"
      }
    },
    {
      "version": "1.0",
      "library": {
        "path": ".ddx/library",
        "repository": {
          "url": "https://github.com/easel/ddx-library",
          "branch": "main"
        }
      },
      "persona_bindings": {
        "code-reviewer": "strict-code-reviewer"
      }
    }
  ]
}