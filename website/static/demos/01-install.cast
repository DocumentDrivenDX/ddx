[0.520678, "o", "curl -fsSL https://ddx.dev/install.sh | bash\r\n"]
[1.522265, "o", "\r\n$ ddx version\r\n"]
[2.031691, "o", "DDx v0.0.1-dev\r\nCommit: unknown\r\nBuilt: unknown\r\n"]
[3.034381, "o", "\r\n$ ddx --help\r\n"]
[3.542284, "o", "\u001b[36m\r\nв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳ   в–Ҳв–Ҳ\r\nв–Ҳв–Ҳ   в–Ҳв–Ҳ в–Ҳв–Ҳ   в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳ\r\nв–Ҳв–Ҳ   в–Ҳв–Ҳ в–Ҳв–Ҳ   в–Ҳв–Ҳ   в–Ҳв–Ҳв–Ҳ\r\nв–Ҳв–Ҳ   в–Ҳв–Ҳ в–Ҳв–Ҳ   в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳ\r\nв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳ   в–Ҳв–Ҳ\r\n\r\nDocument-Driven Development eXperience\r\n\u001b[0m\r\nDDx is a toolkit for AI-assisted development that helps you:\r\n\r\nвҖў Share templates, prompts, and patterns across projects\r\nвҖў Maintain consistent development practices\r\nвҖў Integrate AI tooling seamlessly\r\nвҖў Contribute improvements back to the community\r\n\r\nGet started:\r\n  ddx init          Initialize DDx in your project\r\n  ddx list          See available resources\r\n  ddx doctor        Check installation and diagnose issues\r\n\r\nMore information:\r\n  Documentation: https://github.com/DocumentDrivenDX/ddx\r\n  Issues & Support: https://github.com/DocumentDrivenDX/ddx/issues\r\n\r\n"]
[3.542716, "o", "Usage:\r\n  ddx [command]\r\n\r\nAvailable Commands:\r\n  agent       Invoke AI agents with harness dispatch, quorum, and session logging\r\n  bead        Manage beads (portable work items)\r\n  completion  Generate completion script\r\n  config      Configure DDx settings\r\n  doc         Document dependency graph and staleness tracking\r\n  doctor      Check installation health and diagnose issues\r\n  exec        Validate and run DDx execution definitions\r\n  help        Help about any command\r\n  init        Initialize DDx in current project\r\n  install     Install a package or resource\r\n  installed   List installed packages\r\n  list        List available DDx resources\r\n  log         Show DDX asset history\r\n  mcp         Manage Model Context Protocol servers\r\n  metric      Validate and run metric definitions\r\n  persona     Manage AI personas for consistent interactions\r\n  prompts     Manage AI prompts\r\n  search      Search available packages\r\n  server      Start the DDx HTTP and MCP server\r\n  status      Show version and status information\r\n  uninstall   Remove an installed package\r\n  update      Update DDx toolkit resources\r\n  upgrade     Upgrade DDx to the latest version\r\n  version     Show version information\r\n\r\nFlags:\r\n      --config string              config file (default is $HOME/.ddx.yml)\r\n  -h, --help                       help for ddx\r\n      --library-base-path string   override path for DDx library location\r\n  -v, --verbose                    verbose output\r\n\r\nUse \"ddx [command] --help\" for more information about a command.\r\n"]
