+func parseWorkGoalFlag(cmd *cobra.Command) *agent.RunGoal {
+	if cmd.Flags().Lookup("goal") == nil {
+		return nil
+	}
+	raw, err := cmd.Flags().GetString("goal")
+	if err != nil {
+		return nil
+	}
+	raw = strings.TrimSpace(raw)
+	if raw == "" {
+		return nil
+	}
+	text := raw
+	if info, statErr := os.Stat(raw); statErr == nil && !info.IsDir() {
+		if data, readErr := os.ReadFile(raw); readErr == nil {
+			text = string(data)
+		}
+	}
+	text = strings.TrimSpace(text)
+	if text == "" {
+		return nil
+	}
+	return &agent.RunGoal{
+		Text:            text,
+		StopPredicate:   "queue_empty",
+		AutonomyPosture: "drain-until-goal",
+	}
+}
