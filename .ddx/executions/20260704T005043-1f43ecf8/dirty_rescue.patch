+	AutonomyPosture string `json:"autonomy_posture,omitempty"`
+}
+
+func normalizeRunGoal(goal *RunGoal) *RunGoal {
+	if goal == nil {
+		return nil
+	}
+	goal.Text = strings.TrimSpace(goal.Text)
+	goal.StopPredicate = strings.TrimSpace(goal.StopPredicate)
+	goal.AutonomyPosture = strings.TrimSpace(goal.AutonomyPosture)
+	if goal.Text == "" && goal.StopPredicate == "" && goal.AutonomyPosture == "" {
+		return nil
+	}
+	return goal
+}
