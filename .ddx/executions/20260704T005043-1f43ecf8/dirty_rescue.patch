+func TestRunState_GoalRoundTripAndReload(t *testing.T) {
+	projectRoot := newRunStateProjectRoot(t)
+	want := RunState{
+		BeadID:    "ddx-goal",
+		AttemptID: "attempt-goal",
+		Goal: &RunGoal{
+			Text:            "Drain the ready queue and stop when the gate is green.",
+			StopPredicate:   "queue_empty",
+			AutonomyPosture: "drain-until-goal",
+		},
+		StartedAt:    time.Date(2026, 5, 9, 4, 0, 0, 0, time.UTC),
+		WorktreePath: filepath.Join(projectRoot, "wt"),
+	}
+	if err := WriteRunState(projectRoot, want); err != nil {
+		t.Fatalf("WriteRunState: %v", err)
+	}
+
+	got, err := ReadRunState(projectRoot)
+	if err != nil || got == nil {
+		t.Fatalf("ReadRunState: got (%+v, %v)", got, err)
+	}
+	if got.Goal == nil {
+		t.Fatalf("ReadRunState lost goal: %+v", *got)
+	}
+	if got.Goal.Text != want.Goal.Text || got.Goal.StopPredicate != want.Goal.StopPredicate || got.Goal.AutonomyPosture != want.Goal.AutonomyPosture {
+		t.Fatalf("goal did not round trip: got %+v want %+v", got.Goal, want.Goal)
+	}
+
+	reloaded := loadPersistedRunGoal(projectRoot)
+	if reloaded == nil {
+		t.Fatalf("loadPersistedRunGoal returned nil")
+	}
+	if reloaded.Text != want.Goal.Text || reloaded.StopPredicate != want.Goal.StopPredicate || reloaded.AutonomyPosture != want.Goal.AutonomyPosture {
+		t.Fatalf("loadPersistedRunGoal = %+v, want %+v", reloaded, want.Goal)
+	}
+}
